    <script type="application/javascript">

    globalThis.__canvas_resized = (self, ecw, ech) => {
        console.warn("TODO: panda3d canvas monitor", self, ecw, ech)
    }

    // Intro web
    window.colormage_intro_fini = false;
    window.colormage_intro_playing = false;

    // Langue choisie dans les parametres
    window.colormage_langue = (function () {
        try {
            var save = window.localStorage.getItem("colormage_save");
            if (save) {
                var cfg = JSON.parse(save);
                if (cfg && cfg.langue) {
                    return cfg.langue;
                }
            }
        } catch (e) {}
        return "en";
    })();

    var colormage_textes_chargement = {
        fr: {
            chargement: "Chargement...",
            telechargement: "T\u00e9l\u00e9chargement du jeu",
            decompression: "D\u00e9compression",
            compilation: "Compilation des modules",
            pret: "Pr\u00eat !",
            demarrage: "D\u00e9marrage",
            tap: "Touchez pour jouer"
        },
        en: {
            chargement: "Loading...",
            telechargement: "Downloading game",
            decompression: "Extracting",
            compilation: "Compiling modules",
            pret: "Ready!",
            demarrage: "Starting",
            tap: "Tap to play"
        }
    };

    window.colormage_texte_chargement = function (cle) {
        var table = colormage_textes_chargement[window.colormage_langue];
        if (!table) {
            table = colormage_textes_chargement.en;
        }
        if (table[cle]) {
            return table[cle];
        }
        return cle;
    };

    // Barre de progression du chargement pygbag
    window.colormage_progress = { cur: 0, floor: 0, cap: 40, label: window.colormage_texte_chargement("chargement"), done: false };

    function colormage_progress_tick() {
        var p = window.colormage_progress;
        if (p.done) {
            return;
        }
        var pg = document.getElementById("progress");
        if (pg && pg.max) {
            var reel = (pg.value / pg.max) * 100;
            if (reel > p.cap) {
                reel = p.cap;
            }
            if (reel > p.floor) {
                p.floor = reel;
            }
        }
        if (p.cur < p.floor) {
            p.cur += (p.floor - p.cur) * 0.25;
            if (p.floor - p.cur < 0.2) {
                p.cur = p.floor;
            }
        } else if (p.cur < 99) {
            var pas = 0.000833;
            if (p.cur < p.cap) {
                var boost = (p.cap - p.cur) * 0.018;
                if (boost > pas) {
                    pas = boost;
                }
            }
            p.cur += pas;
        }
        if (p.cur > 100) {
            p.cur = 100;
        }
        var fill = document.getElementById("intro-bar-fill");
        var pct = document.getElementById("intro-bar-pct");
        var lbl = document.getElementById("intro-bar-label");
        if (fill) {
            fill.style.width = p.cur.toFixed(1) + "%";
        }
        if (pct) {
            pct.innerText = Math.round(p.cur) + "%";
        }
        if (lbl && lbl.innerText !== p.label) {
            lbl.innerText = p.label;
        }
        requestAnimationFrame(colormage_progress_tick);
    }
    requestAnimationFrame(colormage_progress_tick);

    window.colormage_set_progress = function (plancher, plafond, texte) {
        var p = window.colormage_progress;
        if (plancher !== undefined && plancher !== null && plancher > p.floor) {
            p.floor = plancher;
            if (p.cur < p.floor) {
                p.cur = p.floor;
            }
        }
        if (plafond !== undefined && plafond !== null) {
            p.cap = plafond;
        }
        if (texte !== undefined && texte !== null) {
            p.label = window.colormage_texte_chargement(texte);
        }
    };

    // Debloque l'audio d'intro au premier geste (iOS exige un play() issu du geste)
    (function () {
        function unlock() {
            if (window.colormage_unlocked) return;
            window.colormage_unlocked = true;

            var a = document.getElementById("intro-audio");
            if (a && !window.colormage_intro_playing) {
                a.muted = true;
                a.play().then(function () {
                    if (!window.colormage_intro_playing) {
                        a.pause();
                        a.currentTime = 0;
                    }
                    a.muted = false;
                }).catch(function () { a.muted = false; });
            }
            try {
                var actx = colormage_actx_get();
                if (actx.state === "suspended") {
                    actx.resume();
                }
            } catch (e) {}
            document.removeEventListener("pointerdown", unlock, true);
            document.removeEventListener("touchstart", unlock, true);
            document.removeEventListener("touchend", unlock, true);
            document.removeEventListener("click", unlock, true);
            document.removeEventListener("keydown", unlock, true);
        }
        document.addEventListener("pointerdown", unlock, true);
        document.addEventListener("touchstart", unlock, true);
        document.addEventListener("touchend", unlock, true);
        document.addEventListener("click", unlock, true);
        document.addEventListener("keydown", unlock, true);
    })();

    document.addEventListener("touchmove", function (e) {
        e.preventDefault();
    }, { passive: false });

    // Affiche "Touchez pour jouer" quand pygbag attend le geste utilisateur
    window.colormage_show_tap_prompt = function () {
        var tap = document.getElementById("intro-tap");
        if (tap) {
            tap.innerText = window.colormage_texte_chargement("tap");
            tap.style.display = "block";
        }
    };

    function colormage_play_intro(volume) {
        window.colormage_intro_playing = true;
        window.colormage_progress.done = true;
        var pr = document.getElementById("intro-progress");
        if (pr) {
            pr.style.display = "none";
        }
        var v = document.getElementById("intro-video");
        var a = document.getElementById("intro-audio");
        var tap = document.getElementById("intro-tap");
        if (tap) {
            tap.style.display = "none";
        }
        if (a && volume !== undefined && volume !== null) {
            a.volume = volume;
        }
        if (!v) {
            window.colormage_intro_fini = true;
            return;
        }

        var fin = function () {
            try {
                if (a) {
                    a.pause();
                }
            } catch (e) {}
            window.colormage_intro_fini = true;
        };

        v.style.display = "block";
        v.onended = fin;
        v.onerror = fin;
        if (a) {
            try {
                a.currentTime = 0;
            } catch (e) {}
            a.play().catch(function () {});
            
            v.ontimeupdate = function() {
                if (Math.abs(v.currentTime - a.currentTime) > 0.3) {
                    v.currentTime = a.currentTime;
                }
            };
        }

        var p = v.play();
        if (p && p.catch) {
            p.catch(fin);
        }

        // on ne reste pas bloque si la video ne demarre/finit jamais
        setTimeout(function () {
            if (!window.colormage_intro_fini) {
                fin();
            }
        }, 15000);
    }
    window.colormage_play_intro = colormage_play_intro;

    window.colormage_hide_intro = function () {
        window.colormage_progress.done = true;
        var ov = document.getElementById("intro-overlay");
        if (ov) {
            ov.style.display = "none";
        }
        window.colormage_intro_fini = true;
    };

    // Musique de fond gérée par le navigateur
    window.colormage_music_volume = 0.5;
    window.colormage_music_intent = false;
    window.colormage_bg_gain = null;
    window.colormage_music_buffer = null;
    window.colormage_music_source = null;
    window.colormage_music_startTime = 0;
    window.colormage_music_pausedAt = 0;
    window.colormage_music_cache = {};

    window.colormage_preload_music = function(fichier) {
        if (window.colormage_music_cache[fichier]) return Promise.resolve();
        var actx = colormage_actx_get();
        return fetch(fichier).then(function(r) { return r.arrayBuffer(); })
            .then(function(buf) { return actx.decodeAudioData(buf); })
            .then(function(audio) { window.colormage_music_cache[fichier] = audio; })
            .catch(function(e) { console.log("Preload fail:", fichier, e); });
    };

    // Preload lent en arriere-plan
    setTimeout(function() {
        var musics = [
            "assets/audio/main_theme.webaudio",
            "assets/audio/market.webaudio",
            "assets/audio/terra.webaudio",
            "assets/audio/pyros.webaudio",
            "assets/audio/pyros_boss.webaudio",
            "assets/audio/aquaris.webaudio",
            "assets/audio/vortex.webaudio"
        ];
        var i = 0;
        function loadNext() {
            if (i >= musics.length) return;
            window.colormage_preload_music(musics[i]).then(loadNext);
            i++;
        }
        loadNext();
    }, 2000);

    function init_bg_audio() {
        var actx = colormage_actx_get();
        if (!window.colormage_bg_gain) {
            window.colormage_bg_gain = actx.createGain();
            window.colormage_bg_gain.connect(actx.destination);
        }
        window.colormage_bg_gain.gain.value = window.colormage_music_volume;
        return actx;
    }

    function _start_music_source() {
        var actx = init_bg_audio();
        if (window.colormage_music_source) {
            try { window.colormage_music_source.stop(); } catch(e) {}
            try { window.colormage_music_source.disconnect(); } catch(e) {}
        }
        window.colormage_music_source = actx.createBufferSource();
        window.colormage_music_source.buffer = window.colormage_music_buffer;
        window.colormage_music_source.loop = true;
        window.colormage_music_source.connect(window.colormage_bg_gain);
        
        var offset = window.colormage_music_pausedAt % window.colormage_music_buffer.duration;
        if (isNaN(offset)) offset = 0;
        
        window.colormage_music_source.start(0, offset);
        window.colormage_music_startTime = actx.currentTime - offset;
    }

    window.colormage_play_music = function (fichier) {
        var actx = init_bg_audio();
        window.colormage_music_intent = true;
        window.colormage_music_pausedAt = 0;
        
        if (window.colormage_music_source) {
            try { window.colormage_music_source.stop(); } catch(e) {}
            window.colormage_music_source = null;
        }

        if (window.colormage_music_cache[fichier]) {
            window.colormage_music_buffer = window.colormage_music_cache[fichier];
            if (window.colormage_music_intent) {
                _start_music_source();
            }
            return;
        }

        fetch(fichier).then(function(r) {
            return r.arrayBuffer();
        }).then(function(buf) {
            return actx.decodeAudioData(buf);
        }).then(function(audio) {
            window.colormage_music_cache[fichier] = audio;
            window.colormage_music_buffer = audio;
            if (window.colormage_music_intent) {
                _start_music_source();
            }
        }).catch(function(e) {
            console.log("Lecture musique bloquee :", e);
        });
    };
    window.colormage_set_music_volume = function (v) {
        var vol = parseFloat(v);
        window.colormage_music_volume = vol;
        init_bg_audio();
        if (vol > 0 && window.colormage_music_intent && !window.colormage_music_source && window.colormage_music_buffer) {
            _start_music_source();
        }
    };
    window.colormage_stop_music = function () {
        window.colormage_music_intent = false;
        var actx = colormage_actx_get();
        if (window.colormage_music_source) {
            window.colormage_music_pausedAt = actx.currentTime - window.colormage_music_startTime;
            try { window.colormage_music_source.stop(); } catch(e) {}
            window.colormage_music_source = null;
        }
    };

    // Coupe tout l'audio web (appele au quit : pygame.quit() n'arrete pas
    // l'audio gere par le navigateur)
    window.colormage_stop_all_audio = function () {
        window.colormage_stop_music();
        var a = document.getElementById("intro-audio");
        if (a) {
            try { a.pause(); } catch(e) {}
        }
        for (var nom in window.colormage_sfx_loops) {
            var src = window.colormage_sfx_loops[nom];
            if (src) {
                try { src.stop(); } catch(e) {}
            }
        }
        window.colormage_sfx_loops = {};
    };

    // Effets sonores via Web Audio API
    window.colormage_actx = null;
    window.colormage_sfx_buffers = {};
    window.colormage_sfx_loops = {};
    function colormage_actx_get() {
        if (window.colormage_actx === null) {
            var AC = window.AudioContext || window.webkitAudioContext;
            window.colormage_actx = new AC();
        }
        return window.colormage_actx;
    }
    window.colormage_load_sfx = function (nom) {
        if (window.colormage_sfx_buffers[nom]) {
            return;
        }
        var actx = colormage_actx_get();
        if (actx.state === "suspended") {
            actx.resume();
        }
        fetch(nom).then(function (r) {
            return r.arrayBuffer();
        }).then(function (buf) {
            return actx.decodeAudioData(buf);
        }).then(function (audio) {
            window.colormage_sfx_buffers[nom] = audio;
        }).catch(function () {});
    };
    window.colormage_play_sfx = function (json_str) {
        var args = JSON.parse(json_str);
        var nom = args.nom;
        var volume = args.volume;
        var boucle = args.boucle;
        var actx = colormage_actx_get();
        var buffer = window.colormage_sfx_buffers[nom];
        if (!actx || !buffer) {
            return;
        }

        var src = actx.createBufferSource();
        src.buffer = buffer;
        var gain = actx.createGain();
        gain.gain.value = volume;

        src.connect(gain);
        gain.connect(actx.destination);
        src.loop = boucle;
        src.start(0);

        if (boucle) {
            var prec = window.colormage_sfx_loops[nom];
            if (prec) {
                try {
                    prec.src.stop();
                } catch (e) {}
            }
            window.colormage_sfx_loops[nom] = { src: src, gain: gain };
        }
    };
    window.colormage_set_sfx_volume = function (json_str) {
        var args = JSON.parse(json_str);
        var nom = args.nom;
        var volume = args.volume;
        var l = window.colormage_sfx_loops[nom];
        if (l) {
            l.gain.gain.value = volume;
        }
    };
    window.colormage_stop_sfx = function (nom) {
        var l = window.colormage_sfx_loops[nom];
        if (l) {
            try {
                l.src.stop();
            } catch (e) {}
            delete window.colormage_sfx_loops[nom];
        }
    };
    window.colormage_prompt_done = false;
    window.colormage_prompt_result = null;
    window.colormage_prompt_open = false;
    window.colormage_kb_text = "";

    (function () {
        var cm_kb_maj = false;
        var cm_kb_max = 15;

        var cm_kb_layouts = {
            fr: ["1234567890", "azertyuiop", "qsdfghjklm", "wxcvbn"],
            en: ["1234567890", "qwertyuiop", "asdfghjkl", "zxcvbnm"]
        };

        var cm_kb_textes = {
            fr: { annuler: "Annuler", maj: "Maj", espace: "Espace", effacer: "Effacer" },
            en: { annuler: "Cancel", maj: "Shift", espace: "Space", effacer: "Delete" }
        };

        function cm_kb_ajouter(c) {
            if (window.colormage_kb_text.length >= cm_kb_max) {
                return;
            }
            window.colormage_kb_text = window.colormage_kb_text + c;
        }

        function cm_kb_effacer() {
            if (window.colormage_kb_text.length === 0) {
                return;
            }
            window.colormage_kb_text = window.colormage_kb_text.substring(0, window.colormage_kb_text.length - 1);
        }

        function cm_prompt_resolve(value) {
            if (!window.colormage_prompt_open) {
                return;
            }
            window.colormage_prompt_result = value;
            window.colormage_prompt_done = true;
            window.colormage_prompt_open = false;
            var ov = document.getElementById("cm-kb-overlay");
            if (ov) {
                ov.style.display = "none";
            }
        }

        function cm_kb_bouton(label, action, poids) {
            var b = document.createElement("button");
            b.textContent = label;
            b.style.flex = poids;
            b.style.margin = "2px";
            b.style.padding = "6px 0";
            b.style.fontSize = "15px";
            b.style.fontWeight = "bold";
            b.style.borderRadius = "6px";
            b.style.border = "none";
            b.style.background = "#3a2d5c";
            b.style.color = "#ffffff";
            b.style.cursor = "pointer";
            b.style.touchAction = "manipulation";
            b.addEventListener("pointerdown", function (e) {
                e.preventDefault();
                action();
            });
            return b;
        }

        function cm_kb_lettre(lettre) {
            var b = cm_kb_bouton(lettre, function () {
                if (cm_kb_maj) {
                    cm_kb_ajouter(lettre.toUpperCase());
                } else {
                    cm_kb_ajouter(lettre);
                }
            }, "1");
            b.setAttribute("data-lettre", lettre);
            return b;
        }

        function cm_kb_rafraichir_casse() {
            var keys = document.getElementById("cm-kb-keys");
            if (!keys) {
                return;
            }
            var boutons = keys.querySelectorAll("button[data-lettre]");
            var i = 0;
            while (i < boutons.length) {
                var b = boutons[i];
                var lettre = b.getAttribute("data-lettre");
                if (cm_kb_maj) {
                    b.textContent = lettre.toUpperCase();
                } else {
                    b.textContent = lettre;
                }
                i = i + 1;
            }
        }

        function cm_kb_construire(langue) {
            var keys = document.getElementById("cm-kb-keys");
            if (!keys) {
                return;
            }
            keys.innerHTML = "";
            var txt = cm_kb_textes[langue];
            if (!txt) {
                txt = cm_kb_textes.en;
            }
            var layout = cm_kb_layouts[langue];
            if (!layout) {
                layout = cm_kb_layouts.en;
            }
            var r = 0;
            while (r < layout.length) {
                var ligne = document.createElement("div");
                ligne.style.display = "flex";
                ligne.style.justifyContent = "center";
                var rangee = layout[r];
                var k = 0;
                while (k < rangee.length) {
                    ligne.appendChild(cm_kb_lettre(rangee.charAt(k)));
                    k = k + 1;
                }
                keys.appendChild(ligne);
                r = r + 1;
            }

            var actions = document.createElement("div");
            actions.style.display = "flex";
            actions.style.justifyContent = "center";
            actions.appendChild(cm_kb_bouton(txt.maj, function () {
                cm_kb_maj = !cm_kb_maj;
                cm_kb_rafraichir_casse();
            }, "1.5"));
            actions.appendChild(cm_kb_bouton(txt.espace, function () {
                cm_kb_ajouter(" ");
            }, "3"));
            actions.appendChild(cm_kb_bouton(txt.effacer, function () {
                cm_kb_effacer();
            }, "1.5"));
            keys.appendChild(actions);

            var valid = document.createElement("div");
            valid.style.display = "flex";
            valid.style.justifyContent = "center";
            valid.appendChild(cm_kb_bouton(txt.annuler, function () {
                cm_prompt_resolve(null);
            }, "1"));
            var ok = cm_kb_bouton("OK", function () {
                cm_prompt_resolve(window.colormage_kb_text);
            }, "1");
            ok.style.background = "#ffc83c";
            ok.style.color = "#000000";
            valid.appendChild(ok);
            keys.appendChild(valid);
        }

        function cm_kb_clavier(e) {
            if (!window.colormage_prompt_open) {
                return;
            }
            e.stopImmediatePropagation();
            if (e.type !== "keydown") {
                return;
            }
            if (e.key === "Enter") {
                cm_prompt_resolve(window.colormage_kb_text);
                return;
            }
            if (e.key === "Escape") {
                cm_prompt_resolve(null);
                return;
            }
            if (e.key === "Backspace") {
                cm_kb_effacer();
                return;
            }
            if (e.key.length === 1) {
                cm_kb_ajouter(e.key);
            }
        }
        window.addEventListener("keydown", cm_kb_clavier, true);
        window.addEventListener("keyup", cm_kb_clavier, true);
        window.addEventListener("keypress", cm_kb_clavier, true);

        window.colormage_show_prompt = function (json_str) {
            var a = JSON.parse(json_str);
            window.colormage_kb_text = a.val;
            if (!window.colormage_kb_text) {
                window.colormage_kb_text = "";
            }
            cm_kb_maj = false;
            window.colormage_prompt_done = false;
            window.colormage_prompt_result = null;
            window.colormage_prompt_open = true;

            var langue = a.langue;
            if (!langue) {
                langue = "en";
            }
            cm_kb_construire(langue);
            var ov = document.getElementById("cm-kb-overlay");
            if (ov) {
                ov.style.display = "block";
            }
        };
    })();

    // Coupe tout l'audio web (appele au quit : pygame.quit() n'arrete pas
    // l'audio gere par le navigateur)
    window.colormage_stop_all_audio = function () {
        var a = document.getElementById("bg-music");
        if (a) {
            a.pause();
        }
        for (var nom in window.colormage_sfx_loops) {
            var l = window.colormage_sfx_loops[nom];
            if (l) {
                try {
                    l.src.stop();
                } catch (e) {}
            }
        }
        window.colormage_sfx_loops = {};
    };

    document.addEventListener("visibilitychange", function() {
        if (!window.colormage_intro_fini) {
            var v = document.getElementById("intro-video");
            var a = document.getElementById("intro-audio");
            if (!document.hidden && v && a) {
                try {
                    v.currentTime = a.currentTime;
                } catch(e) {}
            }
        }
    });

    async function custom_onload(debug_hidden) {
        // this is called before anything python is loaded
        // make your js customization here
        console.log(__FILE__, "custom_onload")

        pyconsole.hidden = debug_hidden
        system.hidden = debug_hidden
        transfer.hidden = debug_hidden
        info.hidden = debug_hidden
        box.hidden =  debug_hidden

        show_infobox()
    }

    function custom_prerun(){
        // no python main and no (MEMFS + VFS) yet.
        console.log(__FILE__, "custom_prerun")

    }

    function custom_postrun(){
        // python main and no VFS filesystem yet.
        console.log(__FILE__, "custom_postrun")

    }

    function debug() {
        // allow to gain access to dev tools from js console
        // but only on desktop. difficult to reach when in iframe
        python.config.debug = true
        custom_onload(false)
        Module.PyRun_SimpleString("shell.uptime()")
        window_resize()
    }

    function info_inline(data){
        document.getElementById("info").innerHTML = data
    }

    function info_online(url) {
        // display info about current APK
        fetch( url /*, options */)
            .then((response) => response.text())
            .then((html) => {
                info_inline(html);
        })
        .catch((error) => {
            console.warn(error);
        });
    }

    function frame_online(url) {
        window.frames["iframe"].location = url;
    }

    </script>

